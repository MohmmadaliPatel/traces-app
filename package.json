{
  "name": "not-track",
  "version": "1.0.2",
  "main": "start.html",
  "nwbuild": {
    "srcDir": "./*",
    "mode": "build",
    "version": "latest",
    "flavor": "sdk",
    "platform": "linux"
  },
  "scripts": {
    "dev": "blitz dev",
    "build": "rimraf .next && blitz build",
    "start": "npm run seed && kill-port 3000 && start http://localhost:3000 & blitz start",
    "studio": "blitz prisma studio",
    "lint": "eslint --ignore-path .gitignore --ext .js,.ts,.tsx .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "migrate": "blitz prisma migrate deploy",
    "migrate:dev": "blitz prisma migrate dev",
    "seed": "blitz db seed",
    "generate": "blitz prisma generate",
    "pup": "node src/pup.js",
    "try": "node src/test.js"
  },
  "prisma": {
    "schema": "db/schema.prisma"
  },
  "prettier": {
    "semi": false,
    "printWidth": 100
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@blitzjs/auth": "2.0.0-beta.23",
    "@blitzjs/next": "2.0.0-beta.23",
    "@blitzjs/rpc": "2.0.0-beta.23",
    "@hookform/error-message": "2.0.1",
    "@hookform/resolvers": "2.9.11",
    "@types/nodemailer": "6.4.15",
    "adm-zip": "0.5.16",
    "antd": "5.2.2",
    "axios": "1.3.4",
    "axios-cookiejar-support": "4.0.6",
    "axios-rate-limit": "1.4.0",
    "axios-retry": "3.4.0",
    "better-queue": "3.8.12",
    "better-queue-sql": "1.0.6",
    "better-queue-sqlite": "1.0.7",
    "blitz": "2.0.0-beta.23",
    "cheerio": "1.0.0",
    "crypto-js": "4.1.1",
    "csvtojson": "2.0.10",
    "dayjs": "1.11.7",
    "envfile": "6.18.0",
    "express": "4.21.2",
    "fs-extra": "11.1.0",
    "glob": "13.0.0",
    "html2pdf.js": "0.10.2",
    "http-cookie-agent": "6.0.5",
    "http-proxy-agent": "5.0.0",
    "https-proxy-agent": "5.0.1",
    "jose": "4.13.1",
    "json-2-csv": "4.0.0",
    "jsonwebtoken": "9.0.0",
    "jwt-decode": "3.1.2",
    "kill-port": "2.0.1",
    "lodash": "4.17.21",
    "mime-types": "2.1.35",
    "multer": "1.4.5-lts.1",
    "next": "13.1",
    "node-7z": "3.0.0",
    "node-cookie-proxy-agent": "1.1.0",
    "node-cron": "3.0.3",
    "node-machine-id": "1.1.12",
    "nodemailer": "6.10.0",
    "pdf-parse": "1.1.1",
    "pdf-text-reader": "4.0.1",
    "pdfmake": "0.2.20",
    "prisma": "4.6.0",
    "puppeteer": "^23.6.0",
    "puppeteer-extra": "3.3.6",
    "puppeteer-extra-plugin-stealth": "2.11.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "7.43.2",
    "react-js-cron": "5.0.1",
    "secure-password": "4.0.0",
    "socks-proxy-agent": "7.0.0",
    "tough-cookie": "4.1.2",
    "winreg": "1.2.5",
    "xlsx": "0.18.5",
    "zod": "3.20.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "12.0.8",
    "@prisma/client": "4.6.0",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "13.4.0",
    "@testing-library/react-hooks": "8.0.1",
    "@types/better-queue": "3.8.3",
    "@types/fs-extra": "11.0.1",
    "@types/jsonwebtoken": "9.0.1",
    "@types/lodash": "4.14.191",
    "@types/mime-types": "2.1.1",
    "@types/node": "18.11.9",
    "@types/pdfmake": "0.2.12",
    "@types/preview-email": "2.0.1",
    "@types/react": "18.0.25",
    "@types/winreg": "1.2.36",
    "@typescript-eslint/eslint-plugin": "5.42.1",
    "@vitejs/plugin-react": "2.2.0",
    "eslint": "8.27.0",
    "eslint-config-next": "12.3.1",
    "eslint-config-prettier": "8.5.0",
    "husky": "8.0.2",
    "jsdom": "20.0.3",
    "lint-staged": "13.0.3",
    "prettier": "^2.7.1",
    "prettier-plugin-prisma": "4.4.0",
    "pretty-quick": "3.1.3",
    "preview-email": "3.0.7",
    "rimraf": "5.0.0",
    "typescript": "^4.8.4",
    "vite-tsconfig-paths": "3.6.0",
    "vitest": "0.25.3"
  },
  "private": true,
  "bin": "node_modules/next/dist/bin/next",
  "pkg": {
    "assets": [
      ".next/**/*",
      "public"
    ],
    "scripts": [
      ".next/dist/**/*.js"
    ],
    "targets": [
      "latest-win-x64"
    ]
  }
}
